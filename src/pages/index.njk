---
layout: base.njk
title: GitHub Resources
description: Code snippets and markdown resources
permalink: /
---

<main class="page">
  <header class="page__header">
    <h1 class="page__title">GitHub Resources</h1>
    <p class="page__subtitle">Curated code snippets and markdown resources.</p>
  </header>

  <section class="page__search">
    <label class="search__label" for="search-input">Search snippets</label>
    <input
      id="search-input"
      class="search__input"
      type="search"
      placeholder="Search by title, tags, or content"
      data-search-input
    />
    <div class="search__results" data-search-results></div>
  </section>

  <section class="snippet-list">
    {% for snippet in collections.snippets %}
      {% include "snippet-card.njk" %}
    {% endfor %}
  </section>
</main>
