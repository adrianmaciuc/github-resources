<article class="snippet-card" data-category="{{ snippet.data.category }}" data-snippet-url="{{ snippet.url | url }}" data-snippet-slug="{{ snippet.fileSlug }}">
  <header class="snippet-card__header">
    <h2 class="snippet-card__title">{{ snippet.data.title }}</h2>
    <p class="snippet-card__description">{{ snippet.data.description }}</p>
  </header>
  <ul class="snippet-card__tags">
    {% for tag in snippet.data.tags %}
      <li class="tag">{{ tag }}</li>
    {% endfor %}
  </ul>
  <section class="snippet-card__code" data-copy-scope>
    <button class="code-copy" type="button" data-copy-button aria-label="Copy code to clipboard">
      Copy
    </button>
    {{ snippet.templateContent | safe }}
  </section>
  <footer class="snippet-card__footer">
    <a class="snippet-card__link" href="{{ snippet.url | url }}">Open snippet</a>
  </footer>
</article>
