---
layout: base.njk
---
<div class="snippet-page" data-copy-scope>
  <header class="snippet-header">
    <a href="/" class="back-link">
      <span class="icon-arrow-left">←</span> Back to list
    </a>
    <button class="code-copy" type="button" data-copy-button aria-label="Copy code to clipboard">
      Copy
    </button>
  </header>
  
  <article class="snippet-content">
    <h1>{{ title }}</h1>
    {{ content | safe }}
  </article>
</div>
